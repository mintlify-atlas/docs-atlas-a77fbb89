  "keyFeatures": [
    "Canonical 4-skill workflow: $deep-interview → $ralplan → $team / $ralph",
    "Parallel multi-agent team mode with tmux/worktree coordination",
    "Persistent ralph completion loops that keep going until the task is done",
    "Hook plugin system (.omx/hooks/*.mjs) with native event pipeline",
    "Live HUD status bar (omx hud --watch) showing active modes and state",
    "OpenClaw / generic notification gateway for Discord, Slack, Telegram",
    "MCP servers for state, memory, code-intel, team, and tracing",
    "Durable project state under .omx/ (plans, logs, memory, mode tracking)",
    "Sparkshell sidecar for bounded read-only shell inspection",
    "Worktree support for parallel isolated execution environments"
  ],
  "publicApiSurface": [
    "omx (launch Codex with HUD)",
    "omx setup [--scope user|project]",
    "omx doctor [--team]",
    "omx team <N:role> <task>",
    "omx ralph",
    "omx explore --prompt <query>",
    "omx sparkshell <command>",
    "omx hud [--watch] [--json] [--preset=NAME]",
    "omx hooks init|status|validate|test",
    "omx agents-init [path]",
    "omx autoresearch",
    "omx session",
    "omx status",
    "omx cancel",
